{
  "schema_version": 2,
  "id": "pseudoforge.builtin.win_user_pe_comments",
  "description": "Builtin report-only semantic comment rules for Windows user-mode PE cleanup.",
  "rules": [
    {
      "id": "builtin.win_user_pe_hresult.literal",
      "phase": "semantic_comment",
      "priority": 72,
      "confidence": 0.86,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        }
      },
      "match": {
        "regex": "\\b(?P<hresult>0x800(?:04005|70005))\\b"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_hresult",
        "text": "HRESULT literal $hresult should be reviewed as symbolic COM/Win32 failure status",
        "evidence": "HRESULT failure literal is present"
      }
    },
    {
      "id": "builtin.win_user_pe.win32_error.set_last_error",
      "phase": "semantic_comment",
      "priority": 70,
      "confidence": 0.84,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "calls_any": ["SetLastError"]
      },
      "match": {
        "call_site": {
          "function_name": "SetLastError",
          "arg_count": 1,
          "arg_regex": {
            "argument_index": 0,
            "regex": "^(?:2|5|87|122|998|ERROR_[A-Z0-9_]+)u?$"
          }
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_win32_error",
        "text": "SetLastError uses Win32 error value $call_arg0; keep the error role symbolic in review output",
        "evidence": "SetLastError call has a recognizable Win32 error argument"
      }
    },
    {
      "id": "builtin.win_user_pe.win32_error.get_last_error",
      "phase": "semantic_comment",
      "priority": 66,
      "confidence": 0.82,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "calls_any": ["GetLastError"]
      },
      "match": {
        "call_site": {
          "function_name": "GetLastError",
          "arg_count": 0
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_win32_error",
        "text": "GetLastError captures a thread-local Win32 error code; preserve nearby failure predicate context",
        "evidence": "GetLastError call is present"
      }
    },
    {
      "id": "builtin.win_user_pe.argument_roles.createfile",
      "phase": "semantic_comment",
      "priority": 68,
      "confidence": 0.84,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "call_site": {
          "function_name_regex": "^CreateFile[AW]$"
        }
      },
      "match": {
        "call_site": {
          "function_name_regex": "^CreateFile[AW]$",
          "arg_count": 7
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_argument_roles",
        "text": "$call_name arguments map to lpFileName, dwDesiredAccess, dwShareMode, lpSecurityAttributes, dwCreationDisposition, dwFlagsAndAttributes, hTemplateFile",
        "evidence": "CreateFileA/W call arity matches documented kernel32 signature"
      }
    },
    {
      "id": "builtin.win_user_pe.argument_roles.virtualalloc",
      "phase": "semantic_comment",
