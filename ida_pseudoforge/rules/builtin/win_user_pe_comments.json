        "evidence": "VirtualAlloc call arity matches documented kernel32 signature"
      }
    },
    {
      "id": "builtin.win_user_pe.argument_roles.ntqueryinformationprocess",
      "phase": "semantic_comment",
      "priority": 68,
      "confidence": 0.84,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "calls_any": ["NtQueryInformationProcess"]
