      }
    },
    {
      "id": "builtin.win_user_pe.seh.vectored_handler",
      "phase": "semantic_comment",
      "priority": 64,
      "confidence": 0.80,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "call_site": {
          "function_name_regex": "^Rtl(?:Add|Remove)Vectored(?:Exception|Continue)Handler$"
        }
