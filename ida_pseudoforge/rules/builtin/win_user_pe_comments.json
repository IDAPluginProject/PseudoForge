        "evidence": "Vectored exception handler API call is present"
      }
    },
    {
      "id": "builtin.win_user_pe.init.crt",
      "phase": "semantic_comment",
      "priority": 62,
      "confidence": 0.78,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "call_site": {
          "function_name_regex": "^(?:__security_init_cookie|_initterm|_initterm_e|atexit)$"
        }
      },
      "match": {
        "call_site": {
          "function_name_regex": "^(?:__security_init_cookie|_initterm|_initterm_e|atexit)$"
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_init_routine",
        "text": "$call_name is part of user-mode CRT or process initialization scaffolding",
        "evidence": "CRT initialization API/helper is present"
      }
    }
  ]
}
