      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_argument_roles",
        "text": "NtQueryInformationProcess arguments map to ProcessHandle, ProcessInformationClass, ProcessInformation, ProcessInformationLength, ReturnLength",
        "evidence": "NTDLL process query call arity matches documented native API shape"
      }
    },
    {
      "id": "builtin.win_user_pe.handle_lifetime.closehandle",
      "phase": "semantic_comment",
      "priority": 70,
      "confidence": 0.86,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "calls_any": ["CloseHandle"]
      },
      "match": {
        "call_site": {
          "function_name": "CloseHandle",
          "arg_count": 1
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_handle_lifetime",
        "text": "CloseHandle marks a HANDLE lifetime edge; review nearby INVALID_HANDLE_VALUE and NULL checks",
        "evidence": "CloseHandle call is present"
      }
    },
    {
      "id": "builtin.win_user_pe.com_vtable.call",
      "phase": "semantic_comment",
      "priority": 66,
      "confidence": 0.80,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "text_contains": "lpVtbl"
      },
      "match": {
        "regex": "\\b(?P<com_object>[A-Za-z_][A-Za-z0-9_]*)->lpVtbl->(?P<com_method>[A-Za-z_][A-Za-z0-9_]*)\\b"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "win_user_com_vtable",
        "text": "COM vtable dispatch $com_object->$com_method detected; first argument is usually the interface this pointer",
        "evidence": "COM lpVtbl method dispatch pattern is present"
      }
    },
    {
      "id": "builtin.win_user_pe.tls.api",
      "phase": "semantic_comment",
      "priority": 64,
      "confidence": 0.80,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "privilege_domain": ["user", "unknown"]
        },
        "call_site": {
          "function_name_regex": "^Tls(?:Alloc|Free|GetValue|SetValue)$"
