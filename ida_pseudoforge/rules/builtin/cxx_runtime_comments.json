{
  "schema_version": 2,
  "id": "pseudoforge.builtin.cxx_runtime_comments",
  "description": "Builtin report-only semantic comment rules for C++ runtime cleanup hints.",
  "rules": [
    {
      "id": "builtin.cxx_runtime.msvc.vftable_call",
      "phase": "semantic_comment",
      "priority": 68,
      "confidence": 0.82,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "language_runtime": "cxx",
          "abi": "msvc"
        },
        "text_contains": "vf"
      },
      "match": {
        "regex": "\\b(?P<cxx_object>[A-Za-z_][A-Za-z0-9_]*)->(?:vfptr|__vfptr|_vfptr|vftable|__vftable|_vftable)->(?P<cxx_method>[A-Za-z_][A-Za-z0-9_]*)\\b"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "cxx_vtable_call",
        "text": "MSVC-style vtable dispatch $cxx_object->$cxx_method detected; review this pointer and slot owner type",
        "evidence": "MSVC vfptr/vftable dispatch pattern is present"
      }
    },
    {
      "id": "builtin.cxx_runtime.itanium.vptr_call",
      "phase": "semantic_comment",
      "priority": 68,
      "confidence": 0.82,
      "scope": {
        "target": {
          "format": ["elf", "macho", "idb"],
          "language_runtime": "cxx",
          "abi": "itanium"
        },
        "text_contains": "vptr"
      },
      "match": {
        "regex": "\\b(?P<cxx_object>[A-Za-z_][A-Za-z0-9_]*)->(?:_vptr|__vptr|vptr)->(?P<cxx_method>[A-Za-z_][A-Za-z0-9_]*)\\b"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "cxx_vtable_call",
        "text": "Itanium-style vptr dispatch $cxx_object->$cxx_method detected; review this pointer and slot owner type",
        "evidence": "Itanium vptr dispatch pattern is present"
      }
    },
    {
      "id": "builtin.cxx_runtime.msvc.special_member_name",
      "phase": "semantic_comment",
      "priority": 64,
      "confidence": 0.78,
      "scope": {
        "target": {
          "format": ["pe", "idb"],
          "platform": "windows",
          "language_runtime": "cxx",
          "abi": "msvc"
        },
        "function_name_regex": "^\\?\\?[01]"
      },
      "match": {
        "text_contains": "{"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "cxx_ctor_dtor_candidate",
        "text": "MSVC decorated constructor/destructor name detected; preserve object lifetime context",
        "evidence": "Function name matches MSVC constructor/destructor decoration"
      }
    },
    {
      "id": "builtin.cxx_runtime.itanium.special_member_name",
      "phase": "semantic_comment",
      "priority": 64,
      "confidence": 0.78,
      "scope": {
        "target": {
          "format": ["elf", "macho", "idb"],
          "language_runtime": "cxx",
          "abi": "itanium"
        },
        "function_name_regex": "^_ZN.*[CD][012]E"
      },
      "match": {
        "text_contains": "{"
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "cxx_ctor_dtor_candidate",
        "text": "Itanium ABI constructor/destructor name detected; preserve object lifetime context",
        "evidence": "Function name matches Itanium C++ constructor/destructor decoration"
      }
    },
    {
