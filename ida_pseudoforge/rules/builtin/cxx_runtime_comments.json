    {
      "id": "builtin.cxx_runtime.exception_cleanup",
      "phase": "semantic_comment",
      "priority": 62,
      "confidence": 0.78,
      "scope": {
        "target": {
          "format": ["pe", "idb", "elf", "macho"],
          "language_runtime": "cxx"
        },
        "call_site": {
          "function_name_regex": "^(?:__CxxFrameHandler3|_Unwind_Resume|__cxa_throw|__cxa_begin_catch)$"
        }
      },
      "match": {
        "call_site": {
          "function_name_regex": "^(?:__CxxFrameHandler3|_Unwind_Resume|__cxa_throw|__cxa_begin_catch)$"
        }
      },
      "emit": {
        "kind": "semantic_comment",
        "comment_kind": "cxx_exception_cleanup",
        "text": "$call_name marks C++ exception handling or cleanup runtime state",
        "evidence": "C++ exception runtime call is present"
      }
    },
    {
